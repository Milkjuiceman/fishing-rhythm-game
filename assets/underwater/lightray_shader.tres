[gd_resource type="ShaderMaterial" load_steps=4 format=3 uid="uid://d1t7itcndlne6"]

[sub_resource type="Shader" id="Shader_r64kc"]
code = "shader_type spatial;
render_mode unshaded, cull_disabled;
uniform sampler2D t;
void fragment() {
	float shift = sin(TIME+NODE_POSITION_WORLD.z*10.)*0.5+0.5;
	float uv_x = (mix(0., shift, clamp(UV.x, 0., 0.5)) + mix(0., 1.-shift, clamp(UV.x-0.5, 0., 0.5))) * 2.;
	vec4 sample = texture(t, vec2(uv_x, 0.5));
	float fade = 1. - clamp(NODE_POSITION_VIEW.z/4. + 1., 0., 1.);
	ALBEDO = sample.rgb;
	ALPHA = sample.a * fade;
}
"

